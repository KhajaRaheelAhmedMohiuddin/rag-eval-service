# Copy to .env and adjust. Every value has a sensible default — the app runs
# with an empty .env.

# --- LLM (optional) ---
# Leave OPENAI_API_KEY unset to use the offline deterministic model.
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# --- Retrieval ---
TOP_K=4
CHUNK_SIZE=500
CHUNK_OVERLAP=80
GROUNDING_THRESHOLD=0.20

# Retrieval strategy: tfidf | bm25 | hybrid
RETRIEVAL_MODE=hybrid
USE_RERANK=true
RRF_K=60
CANDIDATE_K=10

# --- Prompt versioning ---
PROMPT_VERSION=qa_v2
