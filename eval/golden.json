{
  "description": "Golden evaluation set for the AcmePay RAG service. Each item has a question, the source doc that should be retrieved, answer keywords that must appear in a correct answer, and whether the system should refuse (out-of-scope).",
  "items": [
    {
      "id": "q1",
      "question": "How much does the Premium plan cost per month?",
      "expected_source": "acmepay_fees.md",
      "answer_keywords": ["9.99"],
      "should_refuse": false
    },
    {
      "id": "q2",
      "question": "What is the fee for an instant bank withdrawal?",
      "expected_source": "acmepay_fees.md",
      "answer_keywords": ["1.5%", "10"],
      "should_refuse": false
    },
    {
      "id": "q3",
      "question": "How long do merchant refunds take to process?",
      "expected_source": "acmepay_refunds.md",
      "answer_keywords": ["5", "10", "business days"],
      "should_refuse": false
    },
    {
      "id": "q4",
      "question": "Within how many days must I report an unauthorised transaction?",
      "expected_source": "acmepay_refunds.md",
      "answer_keywords": ["60"],
      "should_refuse": false
    },
    {
      "id": "q5",
      "question": "Is two-factor authentication required?",
      "expected_source": "acmepay_security.md",
      "answer_keywords": ["required", "2fa"],
      "should_refuse": false
    },
    {
      "id": "q6",
      "question": "Which countries is AcmePay available in?",
      "expected_source": "acmepay_security.md",
      "answer_keywords": ["india", "united", "kingdom"],
      "should_refuse": false
    },
    {
      "id": "q7",
      "question": "What is the daily send limit on a Standard account?",
      "expected_source": "acmepay_fees.md",
      "answer_keywords": ["10,000"],
      "should_refuse": false
    },
    {
      "id": "q8",
      "question": "Does AcmePay offer cryptocurrency trading?",
      "expected_source": null,
      "answer_keywords": [],
      "should_refuse": true
    }
  ]
}
